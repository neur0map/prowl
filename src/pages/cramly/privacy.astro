---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

const lastUpdated = 'February 4, 2025';
---

<Layout>
    <!-- Grid overlay -->
    <div class="grid-overlay"></div>

    <!-- Orange accent bar at top -->
    <div class="fixed top-0 left-0 right-0 h-1.5 bg-[#F96302] z-50"></div>

    <main class="relative z-10 pt-1.5">

        <!-- Header -->
        <section class="px-6 py-16 bg-[#FDF8F3]">
            <div class="max-w-3xl mx-auto">
                <!-- Back links -->
                <div class="flex items-center gap-4 mb-8">
                    <a href="/" class="inline-flex items-center gap-2 text-sm font-bold text-[#6B6358] hover:text-[#F96302] transition-colors group">
                        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="square" d="M19 12H5m0 0l6-6m-6 6l6 6"/>
                        </svg>
                        Prowl
                    </a>
                    <span class="text-[#D4C8B8]">/</span>
                    <a href="/cramly" class="text-sm font-bold text-[#6B6358] hover:text-[#F96302] transition-colors">
                        Cramly
                    </a>
                </div>

                <h1 class="text-4xl md:text-5xl font-display text-[#1A1915] mb-4">
                    PRIVACY POLICY
                </h1>
                <p class="text-lg text-[#6B6358]">
                    Cramly - AI Study Buddy
                </p>
                <p class="text-sm font-mono text-[#8A8278] mt-2">
                    Last updated: {lastUpdated}
                </p>
            </div>
        </section>

        <!-- Content -->
        <section class="px-6 py-16 bg-white">
            <div class="absolute top-0 left-0 right-0 h-2 bg-[#1A1915]"></div>

            <article class="max-w-3xl mx-auto prose-custom">

                <div class="space-y-12">

                    <!-- Introduction -->
                    <div>
                        <p class="text-lg text-[#3D3930] leading-relaxed">
                            This Privacy Policy describes how Cramly ("we", "our", or "the extension") collects, uses, and protects your information when you use our Chrome extension. We are committed to protecting your privacy and being transparent about our data practices.
                        </p>
                    </div>

                    <!-- Section 1 -->
                    <div>
                        <h2 class="text-2xl font-display text-[#1A1915] mb-4 flex items-center gap-3">
                            <span class="w-8 h-8 bg-[#F96302] border-2 border-[#1A1915] flex items-center justify-center text-white text-sm">1</span>
                            INFORMATION WE COLLECT
                        </h2>
                        <div class="pl-11 space-y-4 text-[#3D3930]">
                            <p><strong class="text-[#1A1915]">Account Information:</strong> To use Cramly, you must create an account. We collect your email address and password (securely hashed) to authenticate you and manage your account.</p>
                            <p><strong class="text-[#1A1915]">Text Selections:</strong> When you use Cramly to analyze text, we temporarily process the text you've selected on a webpage. This text is sent to our AI service to generate responses.</p>
                            <p><strong class="text-[#1A1915]">Images:</strong> If you use the image analysis feature, the images you submit are temporarily processed to provide explanations and insights.</p>
                            <p><strong class="text-[#1A1915]">Chat History (Optional):</strong> Cramly offers an optional feature to store your latest 5 chat conversations. This feature is opt-in and disabled by default. You can enable or disable it at any time through the extension settings.</p>
                            <p><strong class="text-[#1A1915]">Payment Information:</strong> When you purchase credits or subscribe, payment processing is handled securely by Stripe. We never receive or store your credit card details. Stripe provides us only with confirmation of successful transactions, and we maintain records of your credit balance and subscription status.</p>
                            <p><strong class="text-[#1A1915]">Usage Data:</strong> We may collect anonymous usage statistics such as feature usage frequency to improve the extension. This data cannot be used to identify you personally.</p>
                            <p><strong class="text-[#1A1915]">We do NOT collect:</strong></p>
                            <ul class="list-disc pl-5 space-y-2 text-[#6B6358]">
                                <li>Browsing history or the URLs you visit</li>
                                <li>Data from pages you don't actively use Cramly on</li>
                                <li>Full credit card or payment details</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Section 2 -->
                    <div>
                        <h2 class="text-2xl font-display text-[#1A1915] mb-4 flex items-center gap-3">
                            <span class="w-8 h-8 bg-[#F96302] border-2 border-[#1A1915] flex items-center justify-center text-white text-sm">2</span>
                            HOW WE USE YOUR INFORMATION
                        </h2>
                        <div class="pl-11 space-y-4 text-[#3D3930]">
                            <p>The information we collect is used to:</p>
                            <ul class="list-disc pl-5 space-y-2 text-[#6B6358]">
                                <li>Create and manage your account</li>
                                <li>Authenticate you when you use the extension</li>
                                <li>Provide AI-powered answers and explanations to your questions</li>
                                <li>Analyze images and diagrams you submit</li>
                                <li>Process payments and manage your credit balance</li>
                                <li>Store your chat history if you opt in to this feature</li>
                                <li>Improve the quality and accuracy of our responses</li>
                                <li>Fix bugs and improve extension performance</li>
                                <li>Send important service-related communications</li>
                            </ul>
                            <p>We do not sell, rent, or share your personal data with third parties for marketing purposes.</p>
                        </div>
                    </div>

                    <!-- Section 3 -->
                    <div>
                        <h2 class="text-2xl font-display text-[#1A1915] mb-4 flex items-center gap-3">
                            <span class="w-8 h-8 bg-[#F96302] border-2 border-[#1A1915] flex items-center justify-center text-white text-sm">3</span>
                            THIRD-PARTY SERVICES
                        </h2>
                        <div class="pl-11 space-y-4 text-[#3D3930]">
                            <p>Cramly uses third-party services to provide functionality:</p>
                            <p><strong class="text-[#1A1915]">AI Services:</strong></p>
                            <ul class="list-disc pl-5 space-y-2 text-[#6B6358]">
                                <li>Your selected text or images are sent to AI service providers (such as OpenAI or similar services) for processing</li>
                                <li>These services have their own privacy policies governing how they handle data</li>
                                <li>We select providers that maintain strong privacy and security standards</li>
                            </ul>
                            <p><strong class="text-[#1A1915]">Payment Processing (Stripe):</strong></p>
                            <ul class="list-disc pl-5 space-y-2 text-[#6B6358]">
                                <li>All payments are processed securely by <a href="https://stripe.com" target="_blank" rel="noopener noreferrer" class="text-[#F96302] hover:underline">Stripe</a></li>
                                <li>Your payment information is entered directly into Stripe's secure payment form</li>
                                <li>We never have access to your full card details</li>
                                <li>Review <a href="https://stripe.com/privacy" target="_blank" rel="noopener noreferrer" class="text-[#F96302] hover:underline">Stripe's Privacy Policy</a> for details on how they handle payment data</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Section 4 -->
                    <div>
                        <h2 class="text-2xl font-display text-[#1A1915] mb-4 flex items-center gap-3">
                            <span class="w-8 h-8 bg-[#F96302] border-2 border-[#1A1915] flex items-center justify-center text-white text-sm">4</span>
                            DATA STORAGE & RETENTION
                        </h2>
                        <div class="pl-11 space-y-4 text-[#3D3930]">
                            <p><strong class="text-[#1A1915]">Account Data:</strong> Your email address and hashed password are stored securely in our database for as long as your account exists.</p>
                            <p><strong class="text-[#1A1915]">Chat History:</strong> If you enable the optional chat history feature, your latest 5 conversations are stored on our servers. You can disable this feature at any time, which will delete your stored chat history.</p>
                            <p><strong class="text-[#1A1915]">Local Storage:</strong> User preferences and settings are stored locally in your browser using Chrome's storage API.</p>
                            <p><strong class="text-[#1A1915]">AI Processing:</strong> Text and images sent for AI processing are not permanently stored on our servers. They are processed in real-time and discarded after generating a response.</p>
                            <p><strong class="text-[#1A1915]">Transaction Records:</strong> Records of your purchases and credit balance are retained for accounting and support purposes.</p>
                        </div>
                    </div>

                    <!-- Section 5 -->
                    <div>
                        <h2 class="text-2xl font-display text-[#1A1915] mb-4 flex items-center gap-3">
                            <span class="w-8 h-8 bg-[#F96302] border-2 border-[#1A1915] flex items-center justify-center text-white text-sm">5</span>
                            DATA SECURITY
                        </h2>
                        <div class="pl-11 space-y-4 text-[#3D3930]">
                            <p>We take reasonable measures to protect your information:</p>
                            <ul class="list-disc pl-5 space-y-2 text-[#6B6358]">
                                <li>All data transmission uses HTTPS encryption</li>
                                <li>Passwords are securely hashed and never stored in plain text</li>
                                <li>We follow security best practices in our code</li>
                                <li>We regularly update the extension to address security vulnerabilities</li>
                                <li>Payment processing is handled by Stripe, a PCI Level 1 certified provider</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Section 6 -->
                    <div>
                        <h2 class="text-2xl font-display text-[#1A1915] mb-4 flex items-center gap-3">
                            <span class="w-8 h-8 bg-[#F96302] border-2 border-[#1A1915] flex items-center justify-center text-white text-sm">6</span>
                            YOUR RIGHTS & CHOICES
                        </h2>
                        <div class="pl-11 space-y-4 text-[#3D3930]">
                            <p>You have control over your data:</p>
                            <ul class="list-disc pl-5 space-y-2 text-[#6B6358]">
                                <li><strong>Chat History:</strong> You can enable or disable chat history storage at any time through the extension settings</li>
                                <li><strong>Account Deletion:</strong> You can delete your account at any time. This will permanently remove your account data, including email and stored chat history. Please note that unused credits will not be refunded upon account deletion.</li>
                                <li><strong>Uninstall:</strong> You can remove Cramly at any time, which removes all locally stored data</li>
                                <li><strong>Data Access:</strong> You can request a copy of the personal data we hold about you by contacting us</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Section 7 -->
                    <div>
                        <h2 class="text-2xl font-display text-[#1A1915] mb-4 flex items-center gap-3">
                            <span class="w-8 h-8 bg-[#F96302] border-2 border-[#1A1915] flex items-center justify-center text-white text-sm">7</span>
                            CHILDREN'S PRIVACY
                        </h2>
                        <div class="pl-11 space-y-4 text-[#3D3930]">
                            <p>Cramly is designed to help students study. Users under 13 years of age must have parental consent to create an account and use the service. If you are a parent or guardian and believe your child has created an account without your consent, please contact us so we can take appropriate action.</p>
                        </div>
                    </div>

                    <!-- Section 8 -->
                    <div>
                        <h2 class="text-2xl font-display text-[#1A1915] mb-4 flex items-center gap-3">
                            <span class="w-8 h-8 bg-[#F96302] border-2 border-[#1A1915] flex items-center justify-center text-white text-sm">8</span>
                            CHANGES TO THIS POLICY
                        </h2>
                        <div class="pl-11 space-y-4 text-[#3D3930]">
                            <p>We may update this Privacy Policy from time to time. When we make significant changes, we will:</p>
                            <ul class="list-disc pl-5 space-y-2 text-[#6B6358]">
                                <li>Update the "Last updated" date at the top of this policy</li>
                                <li>Notify users through the extension or via email if the changes are material</li>
                            </ul>
                            <p>We encourage you to review this policy periodically.</p>
                        </div>
                    </div>

                    <!-- Section 9 -->
                    <div>
                        <h2 class="text-2xl font-display text-[#1A1915] mb-4 flex items-center gap-3">
                            <span class="w-8 h-8 bg-[#F96302] border-2 border-[#1A1915] flex items-center justify-center text-white text-sm">9</span>
                            CONTACT US
                        </h2>
                        <div class="pl-11 space-y-4 text-[#3D3930]">
                            <p>If you have questions, concerns, or requests regarding this Privacy Policy or your data, please contact us:</p>
                            <div class="mt-4 p-4 bg-[#FDF8F3] border-2 border-[#E8E0D5]">
                                <p class="font-mono text-sm">
                                    <strong class="text-[#1A1915]">Email:</strong> <a href="mailto:privacy@prowl.sh" class="text-[#F96302] hover:underline">privacy@prowl.sh</a>
                                </p>
                                <p class="font-mono text-sm mt-2">
                                    <strong class="text-[#1A1915]">GitHub:</strong> <a href="https://github.com/neur0map" target="_blank" rel="noopener noreferrer" class="text-[#F96302] hover:underline">github.com/neur0map</a>
                                </p>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Back to Cramly -->
                <div class="mt-16 pt-8 border-t-2 border-[#E8E0D5] flex items-center gap-4">
                    <a href="/cramly" class="btn-secondary inline-flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="square" d="M19 12H5m0 0l6-6m-6 6l6 6"/>
                        </svg>
                        Back to Cramly
                    </a>
                    <a href="/cramly/terms" class="text-sm font-bold text-[#6B6358] hover:text-[#F96302] transition-colors">
                        Terms of Service
                    </a>
                </div>

            </article>
        </section>

    </main>

    <Footer />
</Layout>

<style>
    .prose-custom p {
        line-height: 1.75;
    }

    .prose-custom ul {
        margin-top: 0.5rem;
    }

    .prose-custom strong {
        font-weight: 600;
    }
</style>
