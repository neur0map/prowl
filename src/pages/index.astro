---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Products from '../components/Products.astro';
import OpenSource from '../components/OpenSource.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
    <!-- Grid overlay (workshop blueprint feel) -->
    <div class="grid-overlay"></div>

    <!-- Bold diagonal stripe accent -->
    <div class="fixed top-0 right-0 w-32 h-screen bg-[#F96302] transform skew-x-[-8deg] translate-x-16 opacity-10 pointer-events-none" aria-hidden="true"></div>

    <!-- Orange accent bar at top -->
    <div class="fixed top-0 left-0 right-0 h-1.5 bg-[#F96302] z-50"></div>

    <main class="relative z-10 pt-1.5">
        <Hero />
        <Products />
        <OpenSource />
    </main>

    <Footer />
</Layout>
