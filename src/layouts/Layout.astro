---
import '../styles/global.scss';

// Base domain URL without trailing slash
const domainBaseURL = 'https://prowl.sh';
const ogImageUrl    = 'https://prowl.sh/og.png';

// Website publisher & region
const authorPublisher   = 'Prowl';
const geoRegion         = 'US';

// SEO title, description and keywords
const seoTitle          = 'Prowl | Indie Dev Studio by neur0map';
const seoDescription    = 'Indie dev studio building focused tools for security, developer productivity, and creative AI. Open source CLI tools and focused products. Built by neur0map.';
const seoKeywords       = 'prowl, indie dev studio, neur0map, open source tools, security tools, developer tools, CLI tools, rust, synthidol, ai influencer, cybersecurity, penetration testing, documentation, productivity';

// Twitter card data
const twitter = {
    title:          seoTitle,
    description:    seoDescription,
    image:          ogImageUrl,
    site:           '@neur0map',
    creator:        '@neur0map'
};

// Open graph data
const openGraph = {
    title:          seoTitle,
    description:    seoDescription,
    url:            domainBaseURL,
    image:          ogImageUrl,
    type:           'website',
    locale:         'en_US',
    siteName:       'Prowl'
};

// Dublin core
const dublinCore = {
    title:          'Prowl',
    creator:        authorPublisher,
    publisher:      authorPublisher,
    rights:         authorPublisher,
    description:    seoDescription,
    language:       'en',
    type:           'Software',
    format:         'text/html'
};

---

<!doctype html>
<html lang="en" class="dark">

    <head>

        <!-- Crawler & Robots -->
        <meta name="robots" content="index, follow, noodp, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
        <meta name="revisit-after" content="7 days" />
        <meta name="revisit" content="after 7 days" />

        <!-- Start: Meta-Tags -->
        <meta charset="UTF-8" />
        <meta http-equiv="content-type"         content="text/html; charset=UTF-8">
        <meta http-equiv="Pragma"               content="cache" />
        <meta http-equiv="X-UA-Compatible"      content="IE=edge">
        <meta name="viewport"                   content="width=device-width, initial-scale=1">
        <!-- End: Meta-Tags -->

        <!-- Start: Theming and Favicons -->
        <link rel="icon" type="image/png" href="/favicon.png" />
        <!-- End: Theming and Favicons -->

        <!-- Start: Misc meta tags -->
        <link rel="sitemap"                     href="/sitemap-index.xml" />
        <link rel="canonical"                   href={Astro.url} />

        <meta name="geo.region"                 content={geoRegion}>
        <meta name="author"                     content={authorPublisher}>
        <meta name="publisher"                  content={authorPublisher}>
        <meta name="copyright"                  content={authorPublisher}>
        <!-- End: Misc meta tags -->

        <!-- Start: Facebook open graph -->
        <meta property="og:title"               content={openGraph.title}>
        <meta property="og:description"         content={openGraph.description}>
        <meta property="og:url"                 content={Astro.url}>
        <meta property="og:type"                content={openGraph.type}>
        <meta property="og:image"               content={openGraph.image}>
        <meta property="og:image:secure_url"    content={openGraph.image}>
        <meta property="og:image:type"          content="image/png">
        <meta property="og:image:width"         content="4606">
        <meta property="og:image:height"        content="1536">
        <meta property="og:image:alt"           content="Prowl - Indie Dev Studio">
        <meta property="og:locale"              content={openGraph.locale}>
        <meta property="og:site_name"           content={openGraph.siteName}>
        <!-- End: Facebook open graph -->

        <!-- Start: Twitter card -->
        <meta name="twitter:card"               content="summary_large_image">
        <meta name="twitter:title"              content={twitter.title}>
        <meta name="twitter:description"        content={twitter.description}>
        <meta name="twitter:image"              content={twitter.image}>
        <meta name="twitter:image:alt"          content="Prowl - Indie Dev Studio">
        <meta name="twitter:site"               content={twitter.site}>
        <meta name="twitter:creator"            content={twitter.creator}>
        <!-- End: Twitter card -->

        <!-- Start: Dublin Core (DC) -->
        <meta name="DC.Title"                   content={dublinCore.title}>
        <meta name="DC.Creator"                 content={dublinCore.creator}>
        <meta name="DC.Rights"                  content={dublinCore.rights}>
        <meta name="DC.Publisher"               content={dublinCore.publisher}>
        <meta name="DC.Description"             content={dublinCore.description}>
        <meta name="DC.Language"                content={dublinCore.language}>
        <meta name="DC.Type"                    content={dublinCore.type}>
        <meta name="DC.Format"                  content={dublinCore.format}>
        <!-- End: Dublin Core (DC) -->

        <!-- Title & Description -->
        <title>{seoTitle}</title>
        <meta name="description" content={seoDescription}>
        <meta name="abstract"    content={seoDescription}>
        <meta name="keywords"    content={seoKeywords}>

        <!-- JSON-LD Structured Data -->
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@graph": [
                {
                    "@type": "WebSite",
                    "@id": "https://prowl.sh/#website",
                    "url": "https://prowl.sh",
                    "name": "Prowl",
                    "description": "Indie dev studio building tools for security, productivity, and creative AI",
                    "publisher": {
                        "@type": "Person",
                        "name": "neur0map",
                        "url": "https://github.com/neur0map"
                    }
                },
                {
                    "@type": "Organization",
                    "@id": "https://prowl.sh/#organization",
                    "name": "Prowl",
                    "url": "https://prowl.sh",
                    "logo": "https://prowl.sh/favicon.png",
                    "description": "Indie dev studio by neur0map",
                    "founder": {
                        "@type": "Person",
                        "name": "neur0map"
                    },
                    "sameAs": [
                        "https://github.com/neur0map",
                        "https://twitter.com/neur0map"
                    ]
                },
                {
                    "@type": "WebPage",
                    "@id": "https://prowl.sh/#webpage",
                    "url": "https://prowl.sh",
                    "name": "Prowl - Indie Dev Studio",
                    "isPartOf": {"@id": "https://prowl.sh/#website"},
                    "about": {"@id": "https://prowl.sh/#organization"}
                },
                {
                    "@type": "SoftwareApplication",
                    "name": "Synthidol",
                    "applicationCategory": "MultimediaApplication",
                    "operatingSystem": "Web",
                    "description": "AI influencer creation platform - easier alternative to ComfyUI",
                    "url": "https://synthidol.com",
                    "author": {"@id": "https://prowl.sh/#organization"}
                },
                {
                    "@type": "SoftwareApplication",
                    "name": "IPCrawler",
                    "applicationCategory": "SecurityApplication",
                    "operatingSystem": "Cross-platform",
                    "description": "TUI network reconnaissance tool with DNS, host discovery, and port scanning",
                    "url": "https://github.com/neur0map/ipcrawler",
                    "author": {"@id": "https://prowl.sh/#organization"},
                    "isAccessibleForFree": true
                },
                {
                    "@type": "SoftwareApplication",
                    "name": "Manx",
                    "applicationCategory": "DeveloperApplication",
                    "operatingSystem": "Cross-platform",
                    "description": "Sub-second CLI documentation finder",
                    "url": "https://github.com/neur0map/manx",
                    "author": {"@id": "https://prowl.sh/#organization"},
                    "isAccessibleForFree": true
                }
            ]
        }
        </script>

        <!-- Performance Hints -->
        <link rel="dns-prefetch" href="//github.com">
        <link rel="dns-prefetch" href="//fonts.googleapis.com">
        <link rel="preconnect" href="https://api.github.com">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

        <!-- Additional SEO Meta Tags -->
        <meta name="theme-color" content="#050505">
        <meta name="msapplication-TileColor" content="#050505">
        <meta name="application-name" content="Prowl">
        <meta name="apple-mobile-web-app-title" content="Prowl">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="mobile-web-app-capable" content="yes">

    </head>

    <body class="min-h-screen bg-[#050505] text-zinc-300 antialiased">
        <slot />
    </body>

</html>
