---
interface Product {
    name: string;
    tagline: string;
    description: string;
    category: string;
    status: 'live' | 'beta' | 'coming-soon';
    color: 'orange' | 'teal' | 'rust';
    icon: string;
    url: string;
    cta: string;
    features: string[];
}

const products: Product[] = [
    {
        name: 'Synthidol',
        tagline: 'AI Influencer Studio',
        description: 'Create realistic AI-generated influencers without the complexity of ComfyUI. Intuitive interface, consistent characters, production-ready outputs.',
        category: 'Creative AI',
        status: 'live',
        color: 'orange',
        icon: 'sparkles',
        url: 'https://synthidol.com',
        cta: 'Visit Synthidol',
        features: ['No-code workflow', 'Character consistency', 'Batch generation', 'Commercial license']
    },
    {
        name: 'Cramly',
        tagline: 'Cram Smarter',
        description: 'The ultimate homework helper for students. Solve MCQs instantly, chat with assignments, get clear explanations, and learn faster.',
        category: 'Education',
        status: 'live',
        color: 'teal',
        icon: 'graduation',
        url: '/cramly',
        cta: 'Learn More',
        features: ['Solve MCQs', 'Chat with text', 'Image analysis', 'Chrome Extension']
    }
];

const colorClasses = {
    orange: {
        bg: 'bg-[#F96302]',
        bgLight: 'bg-[#FEF3EB]',
        border: 'border-[#F96302]',
        text: 'text-[#F96302]',
        badge: 'bg-[#F96302] text-white',
    },
    teal: {
        bg: 'bg-[#0D7377]',
        bgLight: 'bg-[#E8F4F4]',
        border: 'border-[#0D7377]',
        text: 'text-[#0D7377]',
        badge: 'bg-[#0D7377] text-white',
    },
    rust: {
        bg: 'bg-[#A84520]',
        bgLight: 'bg-[#F9F0EB]',
        border: 'border-[#A84520]',
        text: 'text-[#A84520]',
        badge: 'bg-[#A84520] text-white',
    }
};

const statusLabels = {
    'live': { text: 'LIVE', class: 'bg-[#2D5A27] text-white font-bold' },
    'beta': { text: 'BETA', class: 'bg-[#F96302] text-white font-bold' },
    'coming-soon': { text: 'SOON', class: 'bg-[#3D3930] text-white font-bold' }
};
---

<section id="products" class="px-6 py-24 md:py-32 bg-white relative">

    <!-- Section divider stripe -->
    <div class="absolute top-0 left-0 right-0 h-2 bg-[#1A1915]"></div>

    <div class="max-w-6xl mx-auto">

        <!-- Section Header -->
        <div class="mb-16">
            <div class="flex items-center gap-4 mb-6 opacity-0 animate-fade-in-up" data-scroll>
                <span class="tag tag-dark">Products</span>
                <div class="flex-1 h-0.5 bg-[#E8E0D5]"></div>
                <span class="font-mono text-sm text-[#6B6358]">02</span>
            </div>

            <h2 class="text-4xl md:text-6xl font-display mb-4 opacity-0 animate-fade-in-up delay-1" data-scroll>
                <span class="text-[#1A1915]">FOCUSED TOOLS,</span><br/>
                <span class="text-[#F96302]">REAL SOLUTIONS</span>
            </h2>

            <p class="text-lg text-[#6B6358] max-w-xl opacity-0 animate-fade-in-up delay-2" data-scroll>
                Commercial products built with the same care as our open source work.
            </p>
        </div>

        <!-- Products Grid -->
        <div class="grid md:grid-cols-2 gap-8">
            {products.map((product, index) => {
                const colors = colorClasses[product.color];
                const status = statusLabels[product.status];

                return (
                    <a
                        href={product.url}
                        target={product.status === 'live' && product.url.startsWith('http') ? '_blank' : undefined}
                        rel={product.status === 'live' && product.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                        class={`group block relative opacity-0 animate-fade-in-up`}
                        style={`animation-delay: ${(index + 3) * 100}ms`}
                        data-scroll
                    >
                        <!-- Shadow layer -->
                        <div class="absolute inset-0 bg-[#1A1915] transform translate-x-2 translate-y-2 transition-transform group-hover:translate-x-3 group-hover:translate-y-3"></div>

                        <!-- Main card -->
                        <div class={`relative ${colors.bgLight} border-3 border-[#1A1915] p-6 md:p-8 transition-transform group-hover:-translate-x-1 group-hover:-translate-y-1`}>

                            <!-- Header -->
                            <div class="flex items-start justify-between mb-6">
                                <div class="flex items-center gap-4">
                                    <!-- Icon -->
                                    <div class={`w-14 h-14 ${colors.bg} border-2 border-[#1A1915] flex items-center justify-center`}>
                                        {product.icon === 'sparkles' && (
                                            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/>
                                            </svg>
                                        )}
                                        {product.icon === 'graduation' && (
                                            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422m-6.16 3.422v7.055"/>
                                            </svg>
                                        )}
                                    </div>
                                    <div>
                                        <h3 class="text-2xl font-display text-[#1A1915]">{product.name}</h3>
                                        <p class={`text-sm font-bold ${colors.text}`}>{product.tagline}</p>
                                    </div>
                                </div>
                                <!-- Status Badge -->
                                <span class={`px-3 py-1 text-xs font-mono tracking-wider ${status.class}`}>
                                    {status.text}
                                </span>
                            </div>

                            <!-- Description -->
                            <p class="text-[#3D3930] leading-relaxed mb-6">
                                {product.description}
                            </p>

                            <!-- Features -->
                            <div class="flex flex-wrap gap-2 mb-6">
                                {product.features.map(feature => (
                                    <span class="px-3 py-1.5 text-xs font-bold uppercase tracking-wide bg-white border-2 border-[#D4C8B8] text-[#3D3930]">
                                        {feature}
                                    </span>
                                ))}
                            </div>

                            <!-- CTA -->
                            <div class="flex items-center justify-between pt-4 border-t-2 border-[#D4C8B8]">
                                <span class="text-xs font-mono uppercase tracking-widest text-[#6B6358]">
                                    {product.category}
                                </span>
                                <span class={`inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wide ${colors.text} group-hover:gap-3 transition-all`}>
                                    {product.cta}
                                    {product.status === 'live' && (
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                                            <path stroke-linecap="square" stroke-linejoin="miter" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                                        </svg>
                                    )}
                                </span>
                            </div>
                        </div>
                    </a>
                );
            })}
        </div>

    </div>
</section>

<style>
    [data-scroll] {
        opacity: 0;
    }

    [data-scroll].is-visible {
        opacity: 1;
    }
</style>

<script>
    // Intersection Observer for scroll animations
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                entry.target.style.opacity = '';
            }
        });
    }, observerOptions);

    document.querySelectorAll('[data-scroll]').forEach(el => observer.observe(el));
</script>
