---
const socials = [
    { name: 'GitHub', url: 'https://github.com/neur0map', icon: 'github' },
    { name: 'Twitter', url: 'https://twitter.com/neur0map', icon: 'twitter' },
];
---

<section class="min-h-[85vh] flex items-center justify-center px-6 py-20">
    <div class="max-w-4xl mx-auto text-center">

        <!-- Brand Mark -->
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-amber-500/10 to-amber-600/5 border border-amber-500/20 mb-8 opacity-0 animate-fade-in-up">
            <span class="brand-mark text-3xl">:}</span>
        </div>

        <!-- Headline -->
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-serif mb-6 opacity-0 animate-fade-in-up delay-1">
            Prowl
        </h1>

        <!-- Tagline -->
        <p class="text-xl md:text-2xl text-zinc-400 font-serif italic mb-4 opacity-0 animate-fade-in-up delay-2">
            Indie Dev Studio
        </p>

        <!-- Description -->
        <p class="text-base md:text-lg text-zinc-500 max-w-xl mx-auto mb-10 leading-relaxed opacity-0 animate-fade-in-up delay-3">
            Building tools at the intersection of <span class="text-amber-400">security</span>,
            <span class="text-cyan-400">developer productivity</span>, and
            <span class="text-violet-400">creative AI</span>.
            Open source foundations, focused products.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12 opacity-0 animate-fade-in-up delay-4">
            <a href="#products" class="btn-primary group">
                <span>View Products</span>
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
            </a>
            <a href="#opensource" class="btn-secondary">
                Open Source Tools
            </a>
        </div>

        <!-- Social Links -->
        <div class="flex items-center justify-center gap-6 opacity-0 animate-fade-in-up delay-5">
            {socials.map(social => (
                <a
                    href={social.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-zinc-600 hover:text-zinc-300 transition-colors duration-200"
                    title={social.name}
                >
                    {social.icon === 'github' && (
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                        </svg>
                    )}
                    {social.icon === 'twitter' && (
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                    )}
                </a>
            ))}
            <span class="text-zinc-700">|</span>
            <a
                href="https://github.com/neur0map"
                class="text-xs font-mono text-zinc-600 hover:text-amber-400 transition-colors"
            >
                @neur0map
            </a>
        </div>

    </div>
</section>

<!-- Scroll indicator -->
<div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-fade-in delay-6">
    <div class="w-6 h-10 rounded-full border-2 border-zinc-700 flex items-start justify-center p-2">
        <div class="w-1 h-2 bg-zinc-600 rounded-full animate-bounce"></div>
    </div>
</div>
