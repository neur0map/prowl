---
const currentYear = new Date().getFullYear();

const links = {
    products: [
        { name: 'Synthidol', url: 'https://synthidol.com' },
    ],
    opensource: [
        { name: 'IPCrawler', url: 'https://github.com/neur0map/ipcrawler' },
        { name: 'Manx', url: 'https://github.com/neur0map/manx' },
        { name: 'Cyx', url: 'https://github.com/neur0map/cyx' },
        { name: 'doCrawl', url: 'https://github.com/neur0map/docrawl' },
    ],
    social: [
        { name: 'GitHub', url: 'https://github.com/neur0map' },
        { name: 'Twitter', url: 'https://twitter.com/neur0map' },
        { name: 'Reddit', url: 'https://reddit.com/r/prowl_sh' },
    ]
};
---

<footer class="relative px-6 py-16 bg-[#1A1915]">

    <!-- Top orange stripe -->
    <div class="absolute top-0 left-0 right-0 h-2 bg-[#F96302]"></div>

    <div class="relative z-10 max-w-6xl mx-auto">

        <!-- Main Footer Content -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">

            <!-- Brand -->
            <div class="col-span-2 md:col-span-1">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-12 h-12 bg-[#F96302] border-2 border-[#F96302] flex items-center justify-center">
                        <span class="text-xl font-mono font-bold text-[#FDF8F3]">:}</span>
                    </div>
                    <div>
                        <span class="text-xl font-display text-white">PROWL</span>
                        <p class="text-xs text-[#6B6358] font-mono uppercase tracking-wider">Indie Dev Studio</p>
                    </div>
                </div>
                <p class="text-sm text-[#8A8278] leading-relaxed max-w-xs">
                    Building focused tools at the intersection of security, productivity, and creative AI.
                </p>
            </div>

            <!-- Products -->
            <div>
                <h4 class="text-xs font-mono font-bold uppercase tracking-widest text-[#F96302] mb-4">Products</h4>
                <ul class="space-y-3">
                    {links.products.map(link => (
                        <li>
                            <a
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-sm text-[#8A8278] hover:text-white transition-colors inline-flex items-center gap-2 group font-medium"
                            >
                                {link.name}
                                <svg class="w-3 h-3 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                                </svg>
                            </a>
                        </li>
                    ))}
                    <li>
                        <span class="text-sm text-[#5C554A]">Chrome Extension</span>
                        <span class="ml-2 text-xs text-[#5C554A] font-mono">(soon)</span>
                    </li>
                </ul>
            </div>

            <!-- Open Source -->
            <div>
                <h4 class="text-xs font-mono font-bold uppercase tracking-widest text-[#0D7377] mb-4">Open Source</h4>
                <ul class="space-y-3">
                    {links.opensource.map(link => (
                        <li>
                            <a
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-sm text-[#8A8278] hover:text-white transition-colors font-medium"
                            >
                                {link.name}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            <!-- Connect -->
            <div>
                <h4 class="text-xs font-mono font-bold uppercase tracking-widest text-[#A84520] mb-4">Connect</h4>
                <ul class="space-y-3">
                    {links.social.map(link => (
                        <li>
                            <a
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-sm text-[#8A8278] hover:text-white transition-colors font-medium"
                            >
                                {link.name}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

        </div>

        <!-- Bottom Bar -->
        <div class="pt-8 border-t-2 border-[#2D2A24] flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-xs text-[#5C554A] font-mono">
                &copy; {currentYear} Prowl. Built with code and
                <a
                    href="https://buymeacoffee.com/neur0map"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[#F96302] hover:text-[#FF7519] transition-colors font-bold"
                    title="Buy me a coffee"
                >
                    coffee
                </a>.
            </p>

            <div class="flex items-center gap-4">
                <span class="text-xs font-mono text-[#5C554A]">@neur0map</span>
                <div class="w-8 h-8 bg-[#F96302] flex items-center justify-center">
                    <span class="font-mono text-sm font-bold text-[#1A1915]">:}</span>
                </div>
            </div>
        </div>

    </div>

    <!-- SEO content -->
    <div class="sr-only">
        <h2>Prowl - Indie Dev Studio</h2>
        <p>
            Prowl is an indie developer studio by neur0map, creating focused tools for
            security professionals, developers, and creators. Our products include
            Synthidol (AI influencer creation), open source CLI tools for network
            reconnaissance, documentation search, and developer productivity.
        </p>
        <p>
            Open source tools: IPCrawler (network reconnaissance), Manx (documentation search),
            Cyx (LLM-powered command lookup), doCrawl (docs to markdown converter).
            All built in Rust for speed and reliability.
        </p>
        <span>
            prowl, neur0map, indie dev, developer tools, security tools, open source,
            rust cli, network reconnaissance, ai influencer, synthidol, cybersecurity,
            penetration testing, developer productivity, documentation tools
        </span>
    </div>

</footer>
