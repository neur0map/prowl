---
// Modern, concise about section
---

<div class="space-y-5">

    <!-- Header -->
    <div class="space-y-2">
        <h2 class="text-xl font-bold text-white">About Prowl</h2>
        <p class="text-sm text-gray-400 leading-relaxed">
            Focused CLI tools for cybersecurity and developer workflows. Built for learning, shared to help.
        </p>
    </div>

    <!-- Key Points Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">

        <!-- Philosophy Card -->
        <div class="p-3 rounded-xl border border-gray-800/50 bg-gradient-to-br from-gray-950/50 to-gray-900/30 hover:border-gray-700/50 transition-colors">
            <div class="mb-2">
                <h3 class="text-sm font-semibold text-white">Philosophy</h3>
            </div>
            <p class="text-xs text-gray-400 leading-relaxed">
                <span class="text-amber-400">Small</span>,
                <span class="text-blue-400">clear</span>,
                <span class="text-green-400">dependable</span>.
                Minimal dependencies, fast startup, readable configs. One job done well.
            </p>
        </div>

        <!-- Built With Card -->
        <div class="p-3 rounded-xl border border-gray-800/50 bg-gradient-to-br from-gray-950/50 to-gray-900/30 hover:border-gray-700/50 transition-colors">
            <div class="mb-2">
                <h3 class="text-sm font-semibold text-white">Built With</h3>
            </div>
            <p class="text-xs text-gray-400 leading-relaxed">
                Rust + AI pair programming. I define the idea, review, wire, and test. Learning by building.
            </p>
        </div>

        <!-- Ethics Card -->
        <div class="p-3 rounded-xl border border-red-900/30 bg-gradient-to-br from-red-950/20 to-gray-900/30 hover:border-red-800/40 transition-colors">
            <div class="mb-2">
                <h3 class="text-sm font-semibold text-white">Ethics</h3>
            </div>
            <p class="text-xs text-gray-400 leading-relaxed">
                Authorized use only. Labs, coursework, or explicit permission. Use responsibly.
            </p>
        </div>

        <!-- Community Card -->
        <div class="p-3 rounded-xl border border-gray-800/50 bg-gradient-to-br from-gray-950/50 to-gray-900/30 hover:border-gray-700/50 transition-colors">
            <div class="mb-2">
                <h3 class="text-sm font-semibold text-white">Community</h3>
            </div>
            <p class="text-xs text-gray-400 leading-relaxed">
                Hobby project. Issues and PRs welcome. Stars help. Growing one tool at a time.
            </p>
        </div>

    </div>

    <!-- Quick Stats -->
    <div class="flex items-center justify-center gap-6 py-3 px-4 rounded-xl bg-gray-950/30 border border-gray-800/30">
        <div class="text-center">
            <div class="text-lg font-bold text-amber-400">1</div>
            <div class="text-xs text-gray-500">Security</div>
        </div>
        <div class="w-px h-8 bg-gray-800/50"></div>
        <div class="text-center">
            <div class="text-lg font-bold text-blue-400">3</div>
            <div class="text-xs text-gray-500">Dev</div>
        </div>
        <div class="w-px h-8 bg-gray-800/50"></div>
        <div class="text-center">
            <div class="text-lg font-bold text-green-400">100%</div>
            <div class="text-xs text-gray-500">Rust</div>
        </div>
    </div>

</div>