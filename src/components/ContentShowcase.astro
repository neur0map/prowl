---
interface VideoShowcase {
    name: string;
    description: string;
    youtubeId?: string;
    isComingSoon?: boolean;
    toolType: 'security' | 'dev';
}

const showcaseVideos: VideoShowcase[] = [
    {
        name: 'Manx',
        description: 'Fast CLI documentation search in action',
        youtubeId: '3gINTsmHnYA',
        toolType: 'dev'
    },
    {
        name: 'Cyx',
        description: 'LLM-powered security command lookup demo',
        youtubeId: 'iikQZa36yYc',
        toolType: 'dev'
    },
    {
        name: 'doCrawl',
        description: 'Documentation crawler converting sites to Markdown',
        youtubeId: 'aEBA0nFWaPE',
        toolType: 'dev'
    },
    {
        name: 'IPCrawler',
        description: 'Network reconnaissance and scanning',
        isComingSoon: true,
        toolType: 'security'
    }
];
---

<div class="space-y-5">

    <!-- Header -->
    <div class="space-y-2">
        <h2 class="text-xl font-bold text-white">Video Demos</h2>
        <p class="text-sm text-gray-400">
            Watch the tools in action. Real usage, no fluff.
        </p>
    </div>

    <!-- Videos Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        {showcaseVideos.map(video =>
            <div class="group">
                <div class={`rounded-xl overflow-hidden border transition-all duration-300 ${
                    video.toolType === 'security'
                        ? 'border-amber-700/30 hover:border-amber-600/50 bg-gradient-to-br from-amber-950/5 to-black'
                        : 'border-blue-700/30 hover:border-blue-600/50 bg-gradient-to-br from-blue-950/5 to-black'
                }`}>

                    <!-- Video Embed or Coming Soon -->
                    <div class="relative aspect-video bg-gray-900">
                        {video.youtubeId ? (
                            <iframe
                                class="w-full h-full"
                                src={`https://www.youtube.com/embed/${video.youtubeId}`}
                                title={`${video.name} demo`}
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen
                            ></iframe>
                        ) : (
                            <div class="w-full h-full flex items-center justify-center">
                                <div class="text-center space-y-2">
                                    <div class="w-12 h-12 bg-gray-800/50 rounded-lg flex items-center justify-center mx-auto">
                                        <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                                        </svg>
                                    </div>
                                    <p class="text-sm text-gray-500 font-medium">Coming Soon</p>
                                </div>
                            </div>
                        )}
                    </div>

                    <!-- Video Info -->
                    <div class="p-3 border-t border-gray-800/50">
                        <div class="flex items-center justify-between">
                            <div>
                                <h3 class={`text-sm font-semibold mb-0.5 ${
                                    video.toolType === 'security' ? 'text-amber-400' : 'text-blue-400'
                                }`}>
                                    {video.name}
                                </h3>
                                <p class="text-xs text-gray-400">
                                    {video.description}
                                </p>
                            </div>
                            <span class={`px-2 py-0.5 rounded-md text-xs font-medium whitespace-nowrap ${
                                video.toolType === 'security'
                                    ? 'bg-amber-900/20 text-amber-400'
                                    : 'bg-blue-900/20 text-blue-400'
                            }`}>
                                {video.toolType === 'security' ? 'Security' : 'Dev'}
                            </span>
                        </div>
                    </div>

                </div>
            </div>
        )}
    </div>


</div>