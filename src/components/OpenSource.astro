---
interface Tool {
    name: string;
    category: string;
    description: string;
    type: 'security' | 'dev';
    github: string;
    crates?: string;
    installCommand: string;
}

const tools: Tool[] = [
    {
        name: 'IPCrawler',
        category: 'Network Recon',
        description: 'TUI network reconnaissance tool. Concurrent DNS resolution, host discovery, port scanning, and web analysis.',
        type: 'security',
        github: 'neur0map/ipcrawler',
        installCommand: 'git clone https://github.com/neur0map/ipcrawler.git && cd ipcrawler && make build'
    },
    {
        name: 'Manx',
        category: 'Documentation',
        description: 'Sub-second CLI docs finder. Offline caching, 2.9MB binary, zero dependencies.',
        type: 'dev',
        github: 'neur0map/manx',
        crates: 'manx-cli',
        installCommand: 'cargo install manx-cli'
    },
    {
        name: 'Cyx',
        category: 'CLI Assistant',
        description: 'LLM-powered security command lookup with ONNX semantic search. Supports Perplexity, Groq, Ollama.',
        type: 'dev',
        github: 'neur0map/cyx',
        crates: 'cyx',
        installCommand: 'cargo install cyx'
    },
    {
        name: 'doCrawl',
        category: 'Documentation',
        description: 'Convert docs sites to clean Markdown. Auto-detects Docusaurus, MkDocs, Sphinx, Next.js.',
        type: 'dev',
        github: 'neur0map/docrawl',
        crates: 'docrawl',
        installCommand: 'cargo install docrawl'
    }
];

const securityTools = tools.filter(t => t.type === 'security');
const devTools = tools.filter(t => t.type === 'dev');
---

<section id="opensource" class="px-6 py-24 md:py-32 bg-[#FDF8F3] relative">

    <!-- Diagonal stripe accent -->
    <div class="absolute top-0 left-0 w-full h-32 overflow-hidden" aria-hidden="true">
        <div class="absolute top-0 left-0 right-0 h-2 bg-[#F96302]"></div>
        <div class="absolute top-4 left-0 right-0 h-0.5 bg-[#E8E0D5]"></div>
    </div>

    <div class="max-w-6xl mx-auto relative">

        <!-- Section Header -->
        <div class="mb-16">
            <div class="flex items-center gap-4 mb-6 opacity-0 animate-fade-in-up" data-scroll>
                <span class="tag tag-orange">Open Source</span>
                <div class="flex-1 h-0.5 bg-[#E8E0D5]"></div>
                <span class="font-mono text-sm text-[#6B6358]">03</span>
            </div>

            <h2 class="text-4xl md:text-6xl font-display mb-4 opacity-0 animate-fade-in-up delay-1" data-scroll>
                <span class="text-[#1A1915]">BUILT IN</span><br/>
                <span class="text-[#F96302]">THE OPEN</span>
            </h2>

            <p class="text-lg text-[#6B6358] max-w-xl opacity-0 animate-fade-in-up delay-2" data-scroll>
                CLI tools for security research and developer productivity.
                Small, fast, dependable. <span class="font-bold text-[#A84520]">All written in Rust.</span>
            </p>
        </div>

        <!-- Security Tools -->
        <div class="mb-12">
            <div class="flex items-center gap-4 mb-6 opacity-0 animate-fade-in-up delay-3" data-scroll>
                <div class="w-10 h-10 bg-[#F96302] border-2 border-[#1A1915] flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                    </svg>
                </div>
                <h3 class="text-xl font-display text-[#1A1915]">SECURITY</h3>
                <div class="flex-1 h-0.5 bg-[#F96302]"></div>
            </div>

            <div class="space-y-4">
                {securityTools.map((tool, index) => (
                    <div
                        class="group relative opacity-0 animate-fade-in-up"
                        style={`animation-delay: ${(index + 4) * 75}ms`}
                        data-scroll
                    >
                        <!-- Shadow -->
                        <div class="absolute inset-0 bg-[#1A1915] transform translate-x-1.5 translate-y-1.5 transition-transform group-hover:translate-x-2 group-hover:translate-y-2"></div>

                        <!-- Card -->
                        <div class="relative bg-white border-3 border-[#1A1915] p-5 transition-transform group-hover:-translate-x-0.5 group-hover:-translate-y-0.5">
                            <div class="flex flex-col lg:flex-row lg:items-center gap-4">
                                <!-- Info -->
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-3 mb-2">
                                        <h4 class="text-xl font-display text-[#1A1915]">{tool.name}</h4>
                                        <span class="px-2 py-0.5 text-xs font-mono font-bold bg-[#F96302] text-white">
                                            {tool.category}
                                        </span>
                                    </div>
                                    <p class="text-sm text-[#6B6358] leading-relaxed">{tool.description}</p>
                                </div>

                                <!-- Install Command -->
                                <div class="flex-shrink-0 w-full lg:w-auto">
                                    <div class="flex items-center gap-2 px-4 py-3 bg-[#1A1915] border-2 border-[#1A1915] group/cmd">
                                        <span class="text-[#F96302] font-mono text-sm font-bold">$</span>
                                        <code class="text-xs font-mono text-[#FDF8F3] truncate max-w-[280px]">{tool.installCommand}</code>
                                        <button
                                            onclick={`navigator.clipboard.writeText('${tool.installCommand}'); this.querySelector('svg').classList.add('text-[#2D5A27]'); setTimeout(() => this.querySelector('svg').classList.remove('text-[#2D5A27]'), 1000);`}
                                            class="p-1.5 hover:bg-white/10 transition-colors flex-shrink-0 ml-2"
                                            title="Copy to clipboard"
                                        >
                                            <svg class="w-4 h-4 text-[#6B6358] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                                            </svg>
                                        </button>
                                    </div>
                                </div>

                                <!-- Actions -->
                                <div class="flex items-center gap-2 flex-shrink-0">
                                    <a
                                        href={`https://github.com/${tool.github}`}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center gap-2 px-4 py-2.5 bg-[#FDF8F3] hover:bg-[#F96302] border-2 border-[#1A1915] text-sm font-bold text-[#1A1915] hover:text-white transition-all uppercase tracking-wide"
                                    >
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                                        </svg>
                                        <span class="github-stars font-mono text-xs" data-repo={tool.github}>--</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Dev Tools -->
        <div>
            <div class="flex items-center gap-4 mb-6 opacity-0 animate-fade-in-up delay-4" data-scroll>
                <div class="w-10 h-10 bg-[#0D7377] border-2 border-[#1A1915] flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                    </svg>
                </div>
                <h3 class="text-xl font-display text-[#1A1915]">DEV TOOLS</h3>
                <div class="flex-1 h-0.5 bg-[#0D7377]"></div>
            </div>

            <div class="space-y-4">
                {devTools.map((tool, index) => (
                    <div
                        class="group relative opacity-0 animate-fade-in-up"
                        style={`animation-delay: ${(index + 6) * 75}ms`}
                        data-scroll
                    >
                        <!-- Shadow -->
                        <div class="absolute inset-0 bg-[#1A1915] transform translate-x-1.5 translate-y-1.5 transition-transform group-hover:translate-x-2 group-hover:translate-y-2"></div>

                        <!-- Card -->
                        <div class="relative bg-white border-3 border-[#1A1915] p-5 transition-transform group-hover:-translate-x-0.5 group-hover:-translate-y-0.5">
                            <div class="flex flex-col lg:flex-row lg:items-center gap-4">
                                <!-- Info -->
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-3 mb-2">
                                        <h4 class="text-xl font-display text-[#1A1915]">{tool.name}</h4>
                                        <span class="px-2 py-0.5 text-xs font-mono font-bold bg-[#0D7377] text-white">
                                            {tool.category}
                                        </span>
                                    </div>
                                    <p class="text-sm text-[#6B6358] leading-relaxed">{tool.description}</p>
                                </div>

                                <!-- Install Command -->
                                <div class="flex-shrink-0 w-full lg:w-auto">
                                    <div class="flex items-center gap-2 px-4 py-3 bg-[#1A1915] border-2 border-[#1A1915] group/cmd">
                                        <span class="text-[#0D7377] font-mono text-sm font-bold">$</span>
                                        <code class="text-xs font-mono text-[#FDF8F3] truncate max-w-[280px]">{tool.installCommand}</code>
                                        <button
                                            onclick={`navigator.clipboard.writeText('${tool.installCommand}'); this.querySelector('svg').classList.add('text-[#2D5A27]'); setTimeout(() => this.querySelector('svg').classList.remove('text-[#2D5A27]'), 1000);`}
                                            class="p-1.5 hover:bg-white/10 transition-colors flex-shrink-0 ml-2"
                                            title="Copy to clipboard"
                                        >
                                            <svg class="w-4 h-4 text-[#6B6358] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                                            </svg>
                                        </button>
                                    </div>
                                </div>

                                <!-- Actions -->
                                <div class="flex items-center gap-2 flex-shrink-0">
                                    {tool.crates && (
                                        <a
                                            href={`https://crates.io/crates/${tool.crates}`}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="inline-flex items-center gap-2 px-3 py-2.5 bg-[#FDF8F3] hover:bg-[#A84520] border-2 border-[#1A1915] text-[#A84520] hover:text-white transition-all"
                                            title="View on crates.io"
                                        >
                                            <svg class="w-5 h-5" viewBox="0 0 512 512" fill="currentColor">
                                                <path d="M239.1 6.3l-208 78c-18.7 7-31.1 25-31.1 45v225.1c0 18.2 10.3 34.8 26.5 42.9l208 104c13.5 6.8 29.4 6.8 42.9 0l208-104c16.3-8.1 26.5-24.8 26.5-42.9V129.3c0-20-12.4-37.9-31.1-44.9l-208-78C262 2.2 250 2.2 239.1 6.3zM256 68.4l192 72v1.1l-192 78-192-78v-1.1l192-72zm32 356V275.5l160-65v133.9l-160 80z"/>
                                            </svg>
                                        </a>
                                    )}
                                    <a
                                        href={`https://github.com/${tool.github}`}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center gap-2 px-4 py-2.5 bg-[#FDF8F3] hover:bg-[#0D7377] border-2 border-[#1A1915] text-sm font-bold text-[#1A1915] hover:text-white transition-all uppercase tracking-wide"
                                    >
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                                        </svg>
                                        <span class="github-stars font-mono text-xs" data-repo={tool.github}>--</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Philosophy Banner -->
        <div class="mt-16 relative opacity-0 animate-fade-in-up delay-6" data-scroll>
            <!-- Shadow -->
            <div class="absolute inset-0 bg-[#1A1915] transform translate-x-2 translate-y-2"></div>

            <!-- Card -->
            <div class="relative bg-[#F96302] border-3 border-[#1A1915] p-6 md:p-8">
                <div class="flex flex-col md:flex-row md:items-center gap-6">
                    <div class="flex-1">
                        <h4 class="text-xl font-display text-white mb-2">BUILT FOR LEARNING, SHARED TO HELP</h4>
                        <p class="text-[#FDF8F3]/80 leading-relaxed">
                            These tools are hobby projects built with AI pair programming.
                            I define the ideas, review the code, wire everything together, and test thoroughly.
                            <span class="font-bold text-white">Issues and PRs welcome.</span>
                        </p>
                    </div>
                    <div class="flex items-center gap-6">
                        <div class="text-center px-4">
                            <div class="text-4xl font-display text-white">{tools.length}</div>
                            <div class="text-xs text-white/60 font-mono uppercase tracking-widest">Tools</div>
                        </div>
                        <div class="w-0.5 h-12 bg-white/30"></div>
                        <div class="text-center px-4">
                            <div class="text-4xl font-display text-white">100%</div>
                            <div class="text-xs text-white/60 font-mono uppercase tracking-widest">Rust</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<script>
    // Intersection Observer for scroll animations
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                entry.target.style.opacity = '';
            }
        });
    }, observerOptions);

    document.querySelectorAll('[data-scroll]').forEach(el => observer.observe(el));

    // Fetch GitHub stars
    async function fetchGitHubStars(repo: string) {
        try {
            const response = await fetch(`https://api.github.com/repos/${repo}`);
            const data = await response.json();
            return data.stargazers_count || 0;
        } catch (error) {
            console.error('Error fetching GitHub stars:', error);
            return 0;
        }
    }

    function formatNumber(num: number) {
        if (num >= 1000) {
            return (num / 1000).toFixed(1).replace('.0', '') + 'k';
        }
        return num.toString();
    }

    document.addEventListener('DOMContentLoaded', async () => {
        const githubElements = document.querySelectorAll('.github-stars');
        for (const element of githubElements) {
            const repo = element.getAttribute('data-repo');
            if (repo) {
                const stars = await fetchGitHubStars(repo);
                element.textContent = `★ ${formatNumber(stars)}`;
            }
        }
    });
</script>
